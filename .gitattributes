# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must always use LF
*.sh text eol=lf

# Docker files must use LF
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Keep Windows batch files with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
