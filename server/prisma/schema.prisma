model UserTelegramBinding {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique @map("user_id")
  telegramUserId   String   @unique @map("telegram_user_id")
  telegramUsername String?  @map("telegram_username")
  firstName        String?  @map("first_name")
  lastName         String?  @map("last_name")
  boundAt          DateTime @default(now()) @map("bound_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_telegram_bindings")
}

model TelegramBindToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("telegram_bind_tokens")
}

model PublicApiToken {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  name        String
  tokenPrefix String    @map("token_prefix")
  tokenHash   String    @unique @map("token_hash")
  scopes      Json      @default("[]")
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenPrefix])
  @@index([revokedAt])
  @@index([expiresAt])
  @@map("public_api_tokens")
}

model PublicPluginActionRateLimitBucket {
  id           Int      @id @default(autoincrement())
  tokenSource  String   @map("token_source")
  tokenId      Int      @map("token_id")
  pluginId     String   @map("plugin_id")
  actionName   String   @map("action_name")
  policy       String   @default("normal")
  requestCount Int      @default(0) @map("request_count")
  resetAt      DateTime @map("reset_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  plugin Plugin @relation(fields: [pluginId], references: [pluginId], onDelete: Cascade)

  @@unique([tokenSource, tokenId, pluginId, actionName])
  @@index([pluginId])
  @@index([resetAt])
  @@map("public_plugin_action_rate_limit_buckets")
}

model PublicPluginActionRateLimitPolicy {
  id              Int      @id @default(autoincrement())
  pluginId        String   @default("*") @map("plugin_id")
  actionName      String   @default("*") @map("action_name")
  rateLimit       String   @map("rate_limit")
  maxRequests     Int      @map("max_requests")
  windowSeconds   Int      @default(60) @map("window_seconds")
  enabled         Boolean  @default(true)
  updatedByUserId Int?     @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation("PublicPluginActionRateLimitPolicyUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([pluginId, actionName, rateLimit])
  @@index([pluginId])
  @@index([rateLimit])
  @@index([enabled])
  @@index([updatedByUserId])
  @@map("public_plugin_action_rate_limit_policies")
}

model OAuthClientApp {
  id              Int      @id @default(autoincrement())
  name            String
  clientId        String   @unique @map("client_id")
  clientSecretHash String  @map("client_secret_hash")
  redirectUris    Json     @default("[]") @map("redirect_uris")
  scopes          Json     @default("[]")
  enabled         Boolean  @default(true)
  createdByUserId Int      @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdBy User @relation("OAuthClientAppCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  authorizationCodes OAuthAuthorizationCode[]
  accessTokens OAuthAccessToken[]
  refreshTokens OAuthRefreshToken[]
  grants OAuthGrant[]

  @@index([clientId])
  @@index([enabled])
  @@index([createdByUserId])
  @@map("oauth_client_apps")
}

model OAuthGrant {
  id               Int       @id @default(autoincrement())
  appId            Int       @map("app_id")
  userId           Int       @map("user_id")
  scopes           Json      @default("[]")
  lastAuthorizedAt DateTime  @default(now()) @map("last_authorized_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  app OAuthClientApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  user User          @relation("OAuthGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  accessTokens OAuthAccessToken[]
  refreshTokens OAuthRefreshToken[]

  @@unique([appId, userId])
  @@index([userId])
  @@index([appId])
  @@index([revokedAt])
  @@map("oauth_grants")
}

model OAuthAuthorizationCode {
  id          Int       @id @default(autoincrement())
  appId       Int       @map("app_id")
  userId      Int       @map("user_id")
  codeHash    String    @unique @map("code_hash")
  redirectUri String    @map("redirect_uri")
  scopes      Json      @default("[]")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  app  OAuthClientApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  user User           @relation("OAuthAuthorizationCodeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("oauth_authorization_codes")
}

model OAuthAccessToken {
  id          Int       @id @default(autoincrement())
  appId       Int       @map("app_id")
  userId      Int       @map("user_id")
  grantId     Int?      @map("grant_id")
  tokenPrefix String    @map("token_prefix")
  tokenHash   String    @unique @map("token_hash")
  scopes      Json      @default("[]")
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  app  OAuthClientApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  user User           @relation("OAuthAccessTokenUser", fields: [userId], references: [id], onDelete: Cascade)
  grant OAuthGrant?   @relation(fields: [grantId], references: [id], onDelete: SetNull)

  @@index([appId])
  @@index([userId])
  @@index([grantId])
  @@index([tokenPrefix])
  @@index([revokedAt])
  @@index([expiresAt])
  @@map("oauth_access_tokens")
}

model OAuthRefreshToken {
  id          Int       @id @default(autoincrement())
  appId       Int       @map("app_id")
  userId      Int       @map("user_id")
  grantId     Int?      @map("grant_id")
  tokenPrefix String    @map("token_prefix")
  tokenHash   String    @unique @map("token_hash")
  scopes      Json      @default("[]")
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  app OAuthClientApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  user User          @relation("OAuthRefreshTokenUser", fields: [userId], references: [id], onDelete: Cascade)
  grant OAuthGrant?  @relation(fields: [grantId], references: [id], onDelete: SetNull)

  @@index([appId])
  @@index([userId])
  @@index([grantId])
  @@index([tokenPrefix])
  @@index([revokedAt])
  @@index([expiresAt])
  @@map("oauth_refresh_tokens")
}

// ==================== 帮助文档模型 ====================

model HelpArticle {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  content   String
  category  String   @default("general")
  sortOrder Int      @default(0) @map("sort_order")
  published Boolean  @default(true)
  pinned    Boolean  @default(false) // 是否置顶，置顶文章会显示在用户后台首页
  createdBy Int?     @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator User? @relation("CreatedArticles", fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("help_articles")
}

// ==================== 系统配置模型 ====================

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  type        String   @default("string") // string, number, boolean, json
  label       String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

// ==================== 流量统计模型 ====================

// 流量快照 (用于增量计算)
model TrafficSnapshot {
  id         Int      @id @default(autoincrement())
  instanceId Int      @unique @map("instance_id")
  rxRaw      BigInt   @map("rx_raw") // 上次采集的原始值
  txRaw      BigInt   @map("tx_raw")
  rxPacketsRaw BigInt @default(0) @map("rx_packets_raw")
  txPacketsRaw BigInt @default(0) @map("tx_packets_raw")
  cpuUsageRaw  BigInt? @map("cpu_usage_raw")
  updatedAt  DateTime @updatedAt @map("updated_at")

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("traffic_snapshots")
}

// 每日流量聚合 (用于图表)
model DailyTraffic {
  id         Int      @id @default(autoincrement())
  instanceId Int      @map("instance_id")
  date       DateTime @db.Date // 只存日期
  rxTotal    BigInt   @map("rx_total")
  txTotal    BigInt   @map("tx_total")

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, date])
  @@index([instanceId, date])
  @@map("daily_traffic")
}

model ResourceRiskPolicy {
  id                         Int      @id @default(autoincrement())
  name                       String   @default("默认策略")
  enabled                    Boolean  @default(true)
  bandwidthWindowMinutes     Int      @default(60) @map("bandwidth_window_minutes")
  bandwidthActiveMinutes     Int      @default(45) @map("bandwidth_active_minutes")
  bandwidthThresholdMbps     Int      @default(100) @map("bandwidth_threshold_mbps")
  cpuWindowMinutes           Int      @default(60) @map("cpu_window_minutes")
  cpuActiveMinutes           Int      @default(45) @map("cpu_active_minutes")
  cpuThresholdPercent        Int      @default(90) @map("cpu_threshold_percent")
  ppsThreshold               Int      @default(20000) @map("pps_threshold")
  packetSmallRatioThreshold  Int      @default(85) @map("packet_small_ratio_threshold")
  qosTiers                   Json     @default("[{\"level\":1,\"bandwidthMbps\":50,\"score\":50},{\"level\":2,\"bandwidthMbps\":30,\"score\":65},{\"level\":3,\"bandwidthMbps\":10,\"score\":80}]") @map("qos_tiers")
  scoreDecayPerHour          Int      @default(3) @map("score_decay_per_hour")
  orderRestrictScore         Int      @default(70) @map("order_restrict_score")
  autoSuspendScore           Int      @default(90) @map("auto_suspend_score")
  autoSuspendEnabled         Boolean  @default(false) @map("auto_suspend_enabled")
  accountOrderRestrictEnabled Boolean @default(true) @map("account_order_restrict_enabled")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@index([enabled])
  @@map("resource_risk_policies")
}

model InstanceRiskState {
  id                    Int      @id @default(autoincrement())
  instanceId            Int      @unique @map("instance_id")
  userId                Int      @map("user_id")
  hostId                Int      @map("host_id")
  score                 Int      @default(0)
  level                 String   @default("normal")
