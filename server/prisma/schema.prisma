}

// ==================== 分布式锁模型 ====================
// LOGIC004: 支持多实例部署的分布式锁

model DistributedLock {
  id         Int      @id @default(autoincrement())
  lockKey    String   @unique @map("lock_key") // 锁的唯一标识
  ownerId    String   @map("owner_id") // 锁持有者ID（进程ID+随机字符串）
  acquiredAt DateTime @map("acquired_at") // 获取时间
