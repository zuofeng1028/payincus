# Incudal environment template
# Copy to .env for local or production deployment, then replace all secrets.

# Runtime
NODE_ENV=production
# Use 127.0.0.1 when frontend and backend are on the same host.
# Use a private intranet IP when frontend Nginx and backend Node run on different hosts.
HOST=127.0.0.1
PORT=3001
# Trust X-Forwarded-* only when the backend is reachable only through trusted Nginx/internal proxy.
TRUST_PROXY=true

# Database
DATABASE_URL=postgresql://incudal:change_me_postgres_password@127.0.0.1:5432/incudal
# Do not set RESET_DATABASE in production. Production resets require the extra
# ALLOW_PRODUCTION_DATABASE_RESET=RESET_PRODUCTION_DATABASE confirmation.

# Redis
REDIS_URL=redis://:change_me_redis_password@127.0.0.1:6379

# Security
# Generate each production secret separately, for example:
# openssl rand -base64 48
JWT_SECRET=change_me_generate_with_openssl_rand_base64_48
COOKIE_SECRET=change_me_generate_with_openssl_rand_base64_48
# ENCRYPTION_KEY protects sensitive stored data. Keep it stable after first deploy.
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_48
ADMIN_EMAIL=admin@payincus.local
ADMIN_PASSWORD=change_me_admin_password

# Public URLs
# Same-origin split deployment recommendation:
# FRONTEND_URL=https://pay.payincus.com
# ADMIN_FRONTEND_URL=https://admin.payincus.com
# PAYMENT_CALLBACK_BASE_URL=https://pay.payincus.com
FRONTEND_URL=https://pay.payincus.com
ADMIN_FRONTEND_URL=https://admin.payincus.com
SITE_URL=https://pay.payincus.com
PAYMENT_CALLBACK_BASE_URL=https://pay.payincus.com

# Frontend/backend separation
# Set false when the backend only serves APIs and static files are hosted by Nginx/CDN.
SERVE_STATIC_CLIENT=false
# Frontend build-time variable. Leave /api for same-origin reverse proxy.
VITE_API_BASE_URL=/api
# Admin frontend build-time variable used to generate customer-facing links.
VITE_CUSTOMER_BASE_URL=https://pay.payincus.com
# User frontend build-time variable used to send admins to the separate admin host.
VITE_ADMIN_BASE_URL=https://admin.payincus.com
# Leave blank for HTTPS same-origin proxy mode. For HTTP-only intranet validation, set COOKIE_SECURE=false.
# For cross-site API domains, set:
# COOKIE_SAME_SITE=none
# COOKIE_SECURE=true
# Keep COOKIE_DOMAIN empty. Customer/admin subdomains must not share refresh cookies.
COOKIE_SAME_SITE=
COOKIE_SECURE=
COOKIE_DOMAIN=

# Payment callback hardening
PAYMENT_CALLBACK_IP_WHITELIST=
PAYMENT_CALLBACK_SKIP_IP_WHITELIST=false

# Logging and operations
LOG_LEVEL=info
DISABLE_REQUEST_LOG=true
ALERT_WEBHOOK_URL=
# Optional comma-separated administrator IDs allowed to run online updates.
# If empty, only the admin username "admin" can manage system updates.
SYSTEM_UPDATE_ALLOWED_ADMIN_IDS=
SYSTEM_UPDATE_LOG_DIR=/opt/incudal/update-logs
SYSTEM_UPDATE_STARTED_BY_USER_ID=
SYSTEM_UPDATE_RELEASE_REPOSITORY=VipMaxxxx/payincus
SYSTEM_UPDATE_RELEASE_TOKEN=
SYSTEM_UPDATE_APPLY_MODE=auto

# Gift card center
# Comma-separated administrator IDs allowed to create, reveal, disable or delete gift cards.
# In production, leaving this empty denies gift card management even for admins.
PAYINCUS_GIFT_CARD_ADMIN_IDS=

# Extension center
PLUGIN_MANAGER_ALLOWED_ADMIN_IDS=
PLUGIN_MARKET_INDEX_URL=https://payincus.com/plugin-market/index.json
PLUGIN_MARKET_TRUSTED_HOSTS=payincus.com,payincus.github.io,github.com,objects.githubusercontent.com,raw.githubusercontent.com
PLUGIN_MARKET_PUBLISH_DIR=/opt/incudal/plugin-market
PLUGIN_MARKET_PUBLIC_BASE_URL=https://payincus.com/plugin-market
PLUGIN_SUBMISSION_PUBLIC_BASE_URL=https://pay.payincus.com
PLUGIN_WEBHOOK_SIGNING_SECRET=change_me_generate_with_openssl_rand_base64_48
PLUGIN_WEBHOOK_TIMEOUT_MS=10000
PLUGIN_INSTALL_DIR=/opt/incudal/plugins
PLUGIN_DATA_DIR=/opt/incudal/plugin-data
PLUGIN_LOG_DIR=/opt/incudal/plugin-logs
PLUGIN_STAGING_DIR=/opt/incudal/plugin-staging
PLUGIN_MAX_PACKAGE_SIZE_MB=20
PLUGIN_STORAGE_BACKUP_SCHEDULE_ENABLED=false
PLUGIN_STORAGE_BACKUP_INTERVAL_HOURS=24
PLUGIN_STORAGE_BACKUP_RETENTION_COUNT=7
THEME_MANAGER_ALLOWED_ADMIN_IDS=
THEME_MARKET_INDEX_URL=https://payincus.com/theme-market/index.json
THEME_MARKET_TRUSTED_HOSTS=payincus.com,payincus.github.io,github.com,objects.githubusercontent.com,raw.githubusercontent.com
THEME_MARKET_PUBLISH_DIR=/opt/incudal/theme-market
THEME_MARKET_PUBLIC_BASE_URL=https://payincus.com/theme-market
THEME_INSTALL_DIR=/opt/incudal/themes
THEME_DATA_DIR=/opt/incudal/theme-data
THEME_STAGING_DIR=/opt/incudal/theme-staging
THEME_MAX_PACKAGE_SIZE_MB=10

# Database pool tuning
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_CONNECTION_TIMEOUT=5000
DB_IDLE_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=30000

# Background jobs
TRAFFIC_CONCURRENCY_PER_HOST=10
TRAFFIC_HOST_CONCURRENCY=3
DB_WORKER_BACKOFF_MS=15000

# Agent release proxy
INCUDAL_AGENT_RELEASE_REPOSITORY=
INCUDAL_AGENT_RELEASE_TOKEN=
# Optional local release directory containing manifest.json and linux-amd64/linux-arm64 binaries.
INCUDAL_AGENT_RELEASE_DIR=
INCUDAL_AGENT_BINARY_URL=
INCUDAL_AGENT_BINARY_SHA256=
